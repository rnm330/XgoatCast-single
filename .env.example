# ===== xgoatcast 环境变量模板 =====
# 复制为 .env 并填写真实值

# 服务端口
PORT=3520

# 对外可访问域名（用于生成长链接，不带末尾斜杠）
PUBLIC_DOMAIN=http://localhost:3520

# 初始管理员密码（首次启动写入 config.json 后此值不再生效）
ADMIN_PASSWORD=xgoatcast-admin

# 声网 Agora 凭证（也可在管理后台配置）
AGORA_APP_ID=
AGORA_APP_CERTIFICATE=

# 允许的画质选项（逗号分隔，可在后台配置）
AGORA_ALLOWED_QUALITIES=540p30,720p30,1080p30,1080p60,1440p30,1440p60,4k30

# KOOK 机器人 Token（也可在管理后台配置）
KOOK_BOT_TOKEN=

# 触发共享的关键词（逗号分隔，消息包含任意词即触发，无需斜杠）
KOOK_TRIGGER_WORDS=屏幕共享,共享屏幕
